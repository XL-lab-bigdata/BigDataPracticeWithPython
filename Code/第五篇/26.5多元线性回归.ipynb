   "source": [
    "import pandas as pd\n",
    "import statsmodels.api as sm\n",
    "\n",
    "# 1.读取数据集并设置自变量和因变量\n",
    "data = pd.read_csv('Concrete_Data_Yeh.csv')\n",
    "X = sm.add_constant(data.drop('csMPa', axis=1))  # 自变量加常数项\n",
    "Y = data['csMPa']  # 因变量\n",
    "\n",
    "# 2.构建模型并输出结果\n",
    "model = sm.OLS(Y, X).fit()\n",
    "print(model.summary())"
   ]
  }
 ],
